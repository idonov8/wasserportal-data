{
  "__requires": [
    {
      "type": "grafana",
      "id": "grafana",
      "name": "Grafana",
      "version": "10.0.0"
    },
    {
      "type": "datasource",
      "id": "marcusolsson-json-datasource",
      "name": "JSON API",
      "version": "0.6.0"
    },
    {
      "type": "panel",
      "id": "timeseries",
      "name": "Time series",
      "version": ""
    }
  ],
  "__inputs": [
    {
      "name": "DS_JSON_API",
      "label": "Station 5866301 JSON datasource",
      "description": "Point this to https://idonov.com/wasserportal-data/stations/5866301.json",
      "type": "datasource",
      "pluginId": "marcusolsson-json-datasource",
      "pluginName": "JSON API"
    }
  ],
  "id": null,
  "uid": "wasserportal-flow-5866301",
  "title": "Wasserportal Berlin - Flow Station 5866301 (Landwehrkanal Zoo)",
  "description": "Daily mean discharge (Durchfluss/Tagesmittelwert) from station 5866301, Landwehrkanal at Zoo",
  "tags": [
    "water",
    "berlin",
    "environment",
    "flow",
    "discharge"
  ],
  "schemaVersion": 39,
  "version": 2,
  "refresh": "1h",
  "time": {
    "from": "now-5y",
    "to": "now"
  },
  "timepicker": {},
  "timezone": "browser",
  "editable": true,
  "graphTooltip": 1,
  "templating": {
    "list": []
  },
  "annotations": {
    "list": []
  },
  "panels": [
    {
      "id": 1,
      "type": "row",
      "title": "Discharge (Durchfluss)",
      "collapsed": false,
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 24,
        "h": 1
      }
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Abfluss / Discharge (m³/s)",
      "gridPos": {
        "x": 0,
        "y": 1,
        "w": 24,
        "h": 12
      },
      "datasource": {
        "type": "marcusolsson-json-datasource",
        "uid": "${DS_JSON_API}"
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "lineWidth": 1,
            "fillOpacity": 10,
            "spanNulls": true
          },
          "displayName": "Abfluss (m³/s)"
        },
        "overrides": []
      },
      "options": {
        "tooltip": {
          "mode": "multi"
        },
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        }
      },
      "targets": [
        {
          "refId": "A",
          "fields": [
            {
              "name": "time",
              "jsonPath": "$.by_parameter['Abfluss'][*].time",
              "type": "time"
            },
            {
              "name": "value",
              "jsonPath": "$.by_parameter['Abfluss'][*].value",
              "type": "number"
            }
          ],
          "cacheDurationSeconds": 300,
          "method": "GET",
          "urlPath": "",
          "params": [],
          "headers": [],
          "body": ""
        }
      ]
    }
  ]
}
